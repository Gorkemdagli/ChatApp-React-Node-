PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Redis (local dev: localhost:6379, Upstash production: *.upstash.io:6380)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_TLS=false

# Swagger Docs (change in production!)
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin_password

# E2E Testing
# SUPABASE_SERVICE_ROLE_KEY above is also used by Playwright (auth.setup.ts)
# to bypass hCaptcha via Admin API magic link — no extra config needed.
# Playwright reads backend/.env automatically via playwright.config.ts.
