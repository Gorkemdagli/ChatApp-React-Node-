# Supabase Configuration
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Backend API & WebSocket Configuration
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000

# hCaptcha Configuration
# 1. Sign up at https://www.hcaptcha.com/
# 2. Get your Site Key and replace YOUR_HCAPTCHA_SITE_KEY
# 3. For local testing with always-pass, you can use the dummy key: 10000000-ffff-ffff-ffff-000000000001
VITE_HCAPTCHA_SITE_KEY=YOUR_HCAPTCHA_SITE_KEY

# ─── E2E Testing (Playwright) ─────────────────────────────
# Authenticated E2E tests bypass hCaptcha via Supabase Admin API.
# Playwright reads SUPABASE_SERVICE_ROLE_KEY from backend/.env automatically.
# No extra frontend config needed for E2E.
# 
# Optional — override the default test user:
# E2E_USER_EMAIL=e2e-test@chatapp.dev
# E2E_USER_PASSWORD=TestPassword123!
